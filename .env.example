# Cloudinary配置
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=nightfall_ugc
# 注意：Cloudinary API Key和Secret应该只在服务器端使用

# 数据库配置（如果添加真实数据库）
DATABASE_URL=postgresql://user:password@localhost:5432/nightfall

# 认证配置
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# 其他服务
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=your-ga-id